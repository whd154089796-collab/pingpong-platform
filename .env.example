# 数据库连接
# Prisma 运行时使用的 PostgreSQL 连接串。生产环境请使用真实数据库地址，但不要提交到 Git。
DATABASE_URL=""

# Prisma 迁移使用的直连数据库连接串。部分云数据库会区分 pooled / unpooled 连接。
DATABASE_URL_UNPOOLED=""

# 认证与会话
# NextAuth/Auth.js 会话签名密钥。生产环境必须使用足够随机的长字符串。
AUTH_SECRET=""

# 管理员二次验证相关密钥。生产环境必须单独设置，不要与 AUTH_SECRET 共用。
ADMIN_REAUTH_SECRET=""

# 站点地址
# 服务端生成邮件链接、证书链接等场景使用。
APP_URL="http://localhost:3000"

# 浏览器端可读取的站点地址，用于前端生成跳转或分享链接。
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 邮件服务：Azure Communication Services Email
# 用于发送邮箱验证码等邮件。留空时相关邮件功能将无法正常工作。
AZURE_COMMUNICATION_CONNECTION_STRING=""
AZURE_EMAIL_FROM=""

# 图片服务：Cloudinary
# 用于头像等图片上传。NEXT_PUBLIC_ 变量会暴露给浏览器，请不要放密钥。
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# 参赛证明 PDF 字体
# 默认可使用仓库中的中文字体路径；部署时需要确认该文件随构建产物一起存在。
CERTIFICATE_FONT_PATH="assets/fonts/NotoSansSC-Regular.ttf"

# 说明：
# NODE_ENV 通常由 Next.js / 部署平台自动设置，一般不需要手动写入 .env。
